# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Database
DATABASE_URL=sqlite+aiosqlite:///./talent_acquisition.db

# Upload settings
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# GitHub (optional - increases rate limit from 60 to 5000 requests/hour)
# Create token at: https://github.com/settings/tokens
GITHUB_ACCESS_TOKEN=

# Azure OpenAI Voice Models (for AI Voice Interview)
# If TTS/Whisper are in a different region, use separate endpoint
AZURE_OPENAI_VOICE_ENDPOINT=https://your-voice-resource.openai.azure.com/
AZURE_OPENAI_VOICE_KEY=your-voice-api-key
AZURE_OPENAI_TTS_DEPLOYMENT=gpt-4o-mini-tts
AZURE_OPENAI_WHISPER_DEPLOYMENT=whisper
